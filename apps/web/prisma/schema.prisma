// Logo Fountain — Prisma schema (MVP core)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships ClientMembership[]
  createdBriefs ProjectBrief[]
}

model Client {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  slug         String   @unique
  billingEmail String?
  vatNumber    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships ClientMembership[]
  projects    Project[]
  orders      ProjectOrder[]
}

model ClientMembership {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @db.Uuid
  userId    String   @db.Uuid
  role      String
  createdAt DateTime @default(now())

  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@index([userId])
}

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @db.Uuid
  status      String
  packageCode String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client        Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orders        ProjectOrder[]
  entitlements  ProjectEntitlement[]
  briefs        ProjectBrief[]

  @@index([clientId])
  @@index([status])
}

model ProjectBrief {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  version   Int
  answers   Json
  createdBy String   @db.Uuid
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    Profile @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@unique([projectId, version])
  @@index([projectId])
  @@index([createdBy])
}

model ProjectOrder {
  id                     String   @id @default(uuid()) @db.Uuid
  projectId              String   @db.Uuid
  clientId               String   @db.Uuid
  status                 String
  currency               String
  totalCents             Int
  stripeCheckoutSessionId String?  @unique
  stripePaymentIntentId   String?  @unique
  campaignSlug           String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([clientId])
}

model ProjectEntitlement {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @db.Uuid
  key        String
  limitInt   Int?
  consumedInt Int     @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId])
}

model StripeEvent {
  eventId     String   @id
  type        String
  createdAt   DateTime
  processedAt DateTime?
}
